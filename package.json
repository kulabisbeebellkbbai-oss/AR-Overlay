{
  "name": "ar-overlay",
  "version": "0.1.0",
  "private": false,
  "description": "Cross-platform AR/XR overlay facility with shared contracts and no-hardware simulation.",
  "type": "module",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "validate:fixtures": "node scripts/validate-fixtures.js",
    "render:fixtures": "node scripts/render-fixtures.js",
    "compare:frames": "node scripts/compare-frames.js",
    "emulate": "node scripts/run-emulators.js --all",
    "check:host-emulators": "node scripts/check-host-emulators.js",
    "verify:platform-scaffolds": "node scripts/verify-platform-scaffolds.js",
    "android:start-emulator": "bash scripts/android-start-emulator.sh",
    "android:emulator-smoke": "bash scripts/android-build-and-emulator-smoke.sh",
    "serve:api": "node scripts/serve-api.js",
    "verify": "npm run validate:fixtures && npm test && npm run compare:frames && npm run render:fixtures && npm run emulate && npm run check:host-emulators && npm run verify:platform-scaffolds"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
