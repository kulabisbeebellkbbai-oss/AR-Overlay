{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/kulabisbeebellkbbai-oss/AR-Overlay/schemas/overlay-scene.schema.json",
  "title": "AR Overlay Scene",
  "type": "object",
  "required": ["version", "id", "viewport", "elements"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "const": "0.1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "viewport": {
      "type": "object",
      "required": ["width", "height"],
      "additionalProperties": false,
      "properties": {
        "width": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "height": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "elements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "x", "y", "width", "height", "z"],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": ["text", "image", "rect"]
          },
          "x": {
            "type": "number"
          },
          "y": {
            "type": "number"
          },
          "width": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "height": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "z": {
            "type": "number"
          }
        }
      }
    }
  }
}
